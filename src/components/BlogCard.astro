---
import type { BlogData } from "../content.config";

interface Props {
  blogData: BlogData;
}
const { blogData } = Astro.props;

const formattedDate = new Date(blogData.publishDate).toLocaleDateString(
  "en-GB",
  { day: "2-digit", month: "2-digit", year: "2-digit" }
);
---

<a
  href={blogData.url}
  target="_blank"
  class="block group rounded-2xl overflow-hidden border border-slate-200 shadow-sm transition hover:shadow-md hover:scale-[1.02] ease-in"
>
  <div class="grid grid-cols-1 md:grid-cols-2">
    <!-- Image -->
    <div class="h-56 md:h-full overflow-hidden">
      <img
        src={`/cover/${blogData.cover}`}
        alt={blogData.title}
        class="h-full w-full object-cover transition-transform duration-300"
      />
    </div>

    <!-- Content -->
    <div class="flex flex-col justify-between p-5 bg-white">
      <div>
        <h2
          class="font-serif text-lg md:text-2xl font-semibold text-slate-900 leading-snug"
        >
          {blogData.title}
        </h2>
        <span
          class="inline-block mb-2 font-mono text-xs md:text-md text-slate-500"
        >
          {formattedDate}
        </span>
      </div>

      <ul class="mt-4 flex flex-wrap gap-2 text-xs md:text-md">
        {
          blogData.tags.map((tag) => (
            <li class="px-3 py-1 rounded-full bg-slate-100 font-mono text-slate-600">
              {tag}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</a>
