---
interface Props {
  title: string;
  colorClass: string;
  url: string;
  logo: string;
}
const { title, url, logo, colorClass } = Astro.props;
---

<a
  href={url}
  target="_blank"
  class={"flex items-center justify-center gap-2 text-lg px-4 py-3 rounded-xl shadow-md transition-transform duration-300 ease-in hover:scale-105 " +
    colorClass}
>
  <img src={`/social/${logo}`} alt={title} class="h-6 w-6" />
  <span class="font-semibold">
    {title}
  </span>
</a>
