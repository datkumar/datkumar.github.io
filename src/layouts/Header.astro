---
import MenuIcon from "../components/MenuIcon.astro";

const navList = [
  { title: "About", href: "/about" },
  { title: "Projects", href: "/projects" },
  { title: "Blog", href: "/blog" },
];
---

<style>
  /* Ensure the menu is initially translated off-screen */
  #nav-menu {
    transform: translateX(100vw);
    transition: transform 0.3s ease-in-out;
  }

  /* When the checkbox is checked, slide the menu back into view */
  #ham-toggle:checked ~ label[for="ham-toggle"] + #nav-menu,
  #ham-toggle:checked ~ #nav-menu {
    transform: translateX(0);
  }

  .shine:hover {
    text-shadow:
      0 0 25px rgb(255, 240, 254),
      0 0 5px rgb(251, 77, 187);
    -moz-transition: all 0.2s ease-in;
    -o-transition: all 0.2s ease-in;
    -webkit-transition: all 0.2s ease-in;
    transition: all 0.2s ease-in;
  }
</style>

<header transition:persist transition:animate="none">
  <div
    class="font-mono relative md:static md:items-center md:flex md:justify-between md:py-2 px-3"
  >
    <!-- Logo -->
    <h1
      class="pt-4 pb-6 text-3xl md:text-4xl font-title font-bold text-indigo-700 shine"
    >
      <a href="/">kumar~</a>
    </h1>

    <nav role="navigation">
      <span hidden>Navigation</span>

      <!-- Desktop: NavLinks -->
      <ul class="hidden md:flex gap-3 justify-evenly p-5">
        {
          navList.map((item) => (
            <li class="px-5 text-pink-600 text-2xl font-bold hover:underline">
              <a href={item.href}>{item.title}</a>
            </li>
          ))
        }
      </ul>

      <!-- Mobile: Hamburger Menu and NavLinks  -->
      <div class="md:hidden">
        <input type="checkbox" name="ham-toggle" id="ham-toggle" hidden />
        <label
          for="ham-toggle"
          title="Toggle Navigation Menu"
          role="button"
          aria-controls="nav-menu"
          class="absolute z-50 top-5 right-5 cursor-pointer"
        >
          <MenuIcon class="fill-pink-600" />
        </label>
        <!-- Show Nav menu popup on top of everything else, so highest z-index -->
        <ul
          id="nav-menu"
          class="fixed top-16 z-9999 right-0 pt-10 h-dvh w-dvw flex flex-col gap-4 items-center justify-start bg-indigo-600"
        >
          {
            navList.map((item) => (
              <li class="py-2 text-white text-3xl font-bold">
                <a href={item.href} class=" hover:underline">
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  // This JavaScript is only to close the menu when a link is clicked,
  // the actual menu toggle is now handled by the <label> and CSS.
  window.addEventListener("load", () => {
    const hamCheckbox = document.getElementById("ham-toggle");
    if (!hamCheckbox) return;

    document.querySelectorAll("#nav-menu a").forEach((link) =>
      link.addEventListener("click", () => {
        // Delay the closing slightly to allow Astro's transition to start
        setTimeout(() => {
          hamCheckbox.checked = false;
        }, 100);
      })
    );
  });
</script>
